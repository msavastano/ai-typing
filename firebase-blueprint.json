{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and global typing statistics.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's profile picture URL."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created."
        },
        "totalLessons": {
          "type": "number",
          "description": "Total number of lessons completed."
        },
        "avgWpm": {
          "type": "number",
          "description": "Average words per minute."
        },
        "avgAccuracy": {
          "type": "number",
          "description": "Average typing accuracy."
        },
        "weakKeys": {
          "type": "string",
          "description": "JSON stringified map of characters to error counts. Decayed by 0.7x each session."
        },
        "bigrams": {
          "type": "string",
          "description": "JSON stringified map of 'expected→typed' key-pair confusions to counts. Decayed by 0.7x each session."
        },
        "topic": {
          "type": "string",
          "description": "User's preferred topic for AI-generated lessons (e.g., general, technology, programming)."
        }
      },
      "required": ["uid", "email", "createdAt", "totalLessons", "avgWpm", "avgAccuracy", "weakKeys", "bigrams", "topic"]
    },
    "TypingLesson": {
      "title": "TypingLesson",
      "description": "A completed typing lesson.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID who completed the lesson."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the lesson was completed."
        },
        "text": {
          "type": "string",
          "description": "The text that was typed."
        },
        "wpm": {
          "type": "number",
          "description": "Words per minute achieved."
        },
        "accuracy": {
          "type": "number",
          "description": "Accuracy achieved (0-100)."
        },
        "duration": {
          "type": "number",
          "description": "Time taken in seconds."
        },
        "mistakes": {
          "type": "string",
          "description": "JSON stringified map of characters to error counts in this lesson."
        },
        "bigrams": {
          "type": "string",
          "description": "JSON stringified map of 'expected→typed' key-pair confusions in this lesson."
        }
      },
      "required": ["uid", "createdAt", "text", "wpm", "accuracy", "duration", "mistakes", "bigrams"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles and aggregate typing stats."
    },
    "/users/{userId}/lessons/{lessonId}": {
      "schema": { "$ref": "#/entities/TypingLesson" },
      "description": "Stores individual completed typing lessons for a user."
    }
  }
}
